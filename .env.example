# Optional. Enables Groq relevance checks and summaries for live RSS articles.
GROQ_API_KEY=
# Cost-efficient default for filtering and short summaries.
GROQ_MODEL=llama-3.1-8b-instant
# Comma-separated watchlist for targeted breaking-news RSS feeds.
WATCHLIST=Kimi Moonshot,Qwen Alibaba,OpenAI Codex

# Optional. Enables sending the generated digest to Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional. Defaults to 4173.
PORT=4173
