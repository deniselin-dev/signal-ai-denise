# Optional. Enables Groq relevance checks and summaries for live RSS articles.
GROQ_API_KEY=
# Cost-efficient default for filtering and short summaries.
GROQ_MODEL=llama-3.1-8b-instant
# Optional. Comma-separated priority watchlist for extra "do not miss" searches.
# This boosts specific names; it does not limit the app's broad AI industry coverage.
WATCHLIST=OpenAI,Anthropic Claude,Google Gemini,DeepMind,Meta Llama,Mistral,DeepSeek,Kimi Moonshot,Qwen Alibaba,xAI Grok,NVIDIA AI chips

# Optional. Enables sending the generated digest to Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional. Defaults to 4173.
PORT=4173
