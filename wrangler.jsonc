{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "signal-ai-briefing",
  "main": "src/worker.mjs",
  "compatibility_date": "2026-07-20",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "triggers": {
    "crons": ["0 0 * * *"]
  },
  "vars": {
    "GROQ_MODEL": "llama-3.1-8b-instant",
    "WATCHLIST": "OpenAI,Anthropic Claude,Google Gemini,DeepMind,Meta Llama,Mistral,DeepSeek,Kimi Moonshot,Qwen Alibaba,xAI Grok,NVIDIA AI chips"
  }
}
